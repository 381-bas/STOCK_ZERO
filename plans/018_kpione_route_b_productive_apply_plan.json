  "postcheck_queries": [
    "SELECT to_regclass(object_name) FROM unnest(ARRAY['cg_raw.kpione_raw_ingest_batch_v1','cg_raw.kpione_raw_ingest_batch_file_v1','cg_raw.kpione_raw_event_photo_staging_v1','cg_core.kpione_event_normalized_v1','cg_core.kpione_day_presence_v1']) AS object_name;",
    "SELECT batch_id,status,coverage_start,coverage_end,file_count,row_count,event_count FROM cg_raw.kpione_raw_ingest_batch_v1 ORDER BY created_at DESC;",
    "SELECT batch_id,source_file_sha256,source_file_name,row_count,event_count,validation_status FROM cg_raw.kpione_raw_ingest_batch_file_v1 ORDER BY source_file_sha256;",
    "SELECT batch_id,count(*) AS staged_rows,count(DISTINCT event_id) AS events,min(event_date) AS coverage_start,max(event_date) AS coverage_end FROM cg_raw.kpione_raw_event_photo_staging_v1 GROUP BY batch_id;",
    "SELECT duplicate_classification,count(*) FROM cg_raw.kpione_raw_event_photo_staging_v1 GROUP BY duplicate_classification;",
    "SELECT conflict_classification,count(*) FROM cg_raw.kpione_raw_event_photo_staging_v1 GROUP BY conflict_classification;",
    "SELECT count(*) FROM cg_core.kpione_event_normalized_v1;",
    "SELECT count(*) FROM cg_core.kpione_day_presence_v1 WHERE presence=1;",
    "SELECT count(*) FROM cg_raw.kpione_raw_ingest_batch_v1 WHERE status='ACTIVE';",
    "SELECT count(*) FROM cg_raw.kpione_raw_ingest_batch_v1 a JOIN cg_raw.kpione_raw_ingest_batch_v1 b ON a.batch_id<b.batch_id AND a.status='ACTIVE' AND b.status='ACTIVE' AND daterange(a.coverage_start,a.coverage_end,'[]') && daterange(b.coverage_start,b.coverage_end,'[]');",
    "SELECT to_regclass('cg_raw.kpione2_raw') AS legacy_object_unchanged;"
  ],
